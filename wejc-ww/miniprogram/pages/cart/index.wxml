<navigation-bar title="购物车" back="{{false}}" color="{{navFrontColor}}" background="{{navBackgroundColor}}"></navigation-bar>

<scroll-view class="cart-scroll" scroll-y style="{{themeStyle}}">
  <view class="cart-shell">
    <view wx:if="{{items.length === 0}}" class="empty-card">
      <text>购物车还是空的，先去挑些商品吧。</text>
    </view>

    <view wx:for="{{items}}" wx:key="skuId" class="cart-card">
      <image wx:if="{{item.cover}}" class="cart-cover" src="{{item.cover}}" mode="aspectFill"></image>
      <view class="cart-body">
        <text class="cart-title">{{item.productTitle}}</text>
        <text class="cart-meta">{{item.skuText}}</text>
        <text class="cart-meta">¥{{item.price}}</text>
        <view class="cart-actions">
          <view class="qty-controller">
            <button class="qty-btn" data-product-id="{{item.productId}}" data-sku-id="{{item.skuId}}" data-qty="{{item.qty}}" bindtap="decreaseQty">-</button>
            <text class="qty-value">{{item.qty}}</text>
            <button class="qty-btn" data-product-id="{{item.productId}}" data-sku-id="{{item.skuId}}" data-qty="{{item.qty}}" bindtap="increaseQty">+</button>
          </view>
          <button class="link-btn" data-product-id="{{item.productId}}" data-sku-id="{{item.skuId}}" bindtap="removeItem">移除</button>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<view class="cart-footer" style="{{themeStyle}}">
  <view>
    <text class="footer-label">合计</text>
    <text class="footer-value">¥{{totalAmount}}</text>
  </view>
  <button class="primary-btn" bindtap="goCheckout">去下单</button>
</view>
