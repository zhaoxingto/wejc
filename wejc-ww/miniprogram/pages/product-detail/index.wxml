<navigation-bar title="{{detail ? detail.title : '商品详情'}}" color="{{navFrontColor}}" background="{{navBackgroundColor}}"></navigation-bar>

<scroll-view class="detail-scroll" scroll-y style="{{themeStyle}}">
  <view class="detail-shell" wx:if="{{detail}}">
    <image wx:if="{{detail.cover}}" class="detail-cover" src="{{detail.cover}}" mode="aspectFill"></image>

    <view class="detail-card">
      <text class="detail-title">{{detail.title}}</text>
      <text class="detail-subtitle">{{detail.subtitle || '从规格中选择合适版本后加入购物车。'}}</text>
    </view>

    <view class="detail-card">
      <text class="block-title">可选规格</text>
      <view class="sku-list">
        <view
          wx:for="{{detail.skus}}"
          wx:key="id"
          class="sku-card {{selectedSkuId === item.id ? 'sku-card-active' : ''}}"
          data-sku-id="{{item.id}}"
          bindtap="selectSku"
        >
          <text class="sku-title">{{item.sku_code}}</text>
          <text class="sku-meta">库存 {{item.stock}}</text>
          <text class="sku-meta">价格 ¥{{item.price}}</text>
        </view>
      </view>
    </view>

    <view class="detail-card qty-card">
      <text class="block-title">购买数量</text>
      <view class="qty-controller">
        <button class="qty-btn" bindtap="decreaseQty">-</button>
        <text class="qty-value">{{qty}}</text>
        <button class="qty-btn" bindtap="increaseQty">+</button>
      </view>
    </view>
  </view>
</scroll-view>

<view class="detail-footer" style="{{themeStyle}}">
  <button class="ghost-btn" bindtap="openCart">购物车 {{cartCount}}</button>
  <button class="secondary-btn" bindtap="addToCart">加入购物车</button>
  <button class="primary-btn" bindtap="buyNow">立即下单</button>
</view>
