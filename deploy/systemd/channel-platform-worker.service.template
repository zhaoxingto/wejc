[Unit]
Description=Channel Platform Order Push Worker
After=network.target

[Service]
Type=simple
User=__APP_USER__
WorkingDirectory=__APP_DIR__
EnvironmentFile=__APP_DIR__/.env
ExecStart=__APP_DIR__/.venv/bin/python -m app.tasks.order_push_worker
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
