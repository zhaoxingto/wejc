# REQUIRED: edit these values before first production deploy.
APP_NAME=Channel Commerce Platform
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@127.0.0.1:5432/channel_platform
REDIS_URL=redis://127.0.0.1:6379/0
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
LOG_LEVEL=INFO
ERP_TIMEOUT=10
WORKER_POLL_SECONDS=30

# Optional future settings.
# The current backend does not yet implement admin login,
# so APP_ADMIN_PASSWORD is only a reserved placeholder for future use.
APP_ADMIN_PASSWORD=CHANGE_ME_IF_ADMIN_MODULE_IS_ADDED
